{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": false
  },
  "files": {
    "ignoreUnknown": false,
    "ignore": []
  },
  "formatter": {
    "attributePosition": "auto",
    "enabled": true,
    "indentStyle": "space",
    "lineEnding": "lf",
    "lineWidth": 80
  },
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "noBlankTarget": "off"
        "noRedundantAlt": "error",
        "useAltText": "error",
        "useButtonType": "error",
        "useHtmlLang": "error"
      },
      "complexity": {
        "noUselessFragments": "error",
        "useFlatMap": "error"
      },
      "correctness": {
        "noUnknownFunction": "error",
        "noUnknownUnit": "error",
        "noUnusedImports": "error"
      },
      "nursery": {
        "noValueAtRule": "error"
      },
      "style": {
        "noVar": "error",
        "useConst": "error",
        "useShorthandAssign": "error",
        "noNonNullAssertion": "off"
      },
      "suspicious": {
        "noCompareNegZero": "error",
        "noDuplicateClassMembers": "error",
        "noDuplicateParameters": "error",
        "noRedeclare": "error",
        "noSuspiciousSemicolonInJsx": "error",
        "useIsArray": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "always",
      "attributePosition": "auto",
      "bracketSameLine": false,
      "bracketSpacing": true,
      "quoteProperties": "asNeeded",
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "css": {
    "formatter": {
      "quoteStyle": "double",
      "indentWidth": 2
    },
    "linter": {
      "enabled": true
    }
  },
  "overrides": [
    {
      "include": [
        "*.json"
      ],
      "formatter": {
        "indentWidth": 2
      }
    }
  ]
}